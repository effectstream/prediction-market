    "@prediction-market/midnight-contract/witnesses": "../../shared/contracts/midnight/prediction-market-contract/src/witnesses.ts",

    // Paima packages
    "@paimaexample/concise": "jsr:@paimaexample/concise@0.7.2",
    "@paimaexample/config": "jsr:@paimaexample/config@0.7.2",
