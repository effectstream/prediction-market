{
  "name": "@prediction-market/node",
  "version": "0.1.0",
  "exports": {
    ".": "./src/main.ts"
  },
  "tasks": {
    "check": "echo 'Skipping type check - @types/node resolution issue'",

    "node:start:dev": "deno run -A --inspect=127.0.0.1:9230 --unstable-raw-imports src/main.dev.ts",

    "dev": "EFFECTSTREAM_ENV=dev EFFECTSTREAM_API_PORT=9996 NODE_ENV=development deno run -A --unstable-raw-imports scripts/start.dev.ts",
