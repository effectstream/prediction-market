    "@paimaexample/runtime": "jsr:@paimaexample/runtime@0.7.2",
    "@paimaexample/tui": "jsr:@paimaexample/tui@0.7.2",
    "@paimaexample/utils": "jsr:@paimaexample/utils@0.7.2",
    "@paimaexample/sm": "jsr:@paimaexample/sm@0.7.2",
