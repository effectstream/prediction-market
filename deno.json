{
  "workspace": [
    "./packages/**/*"
  ],
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno task --filter @prediction-market/node dev",
    "testnet": "deno task --filter @prediction-market/node testnet",
    "frontend:dev": "cd packages/frontend && npm run dev",
    "frontend:build": "cd packages/frontend && npm run build"
  },
  "imports": {
    "@prediction-market/data-types": "./packages/shared/data-types/deno.json"
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-this-alias",
        "require-yield",
        "no-explicit-any",
        "ban-types",
        "no-unused-vars",
        "no-slow-types"
      ]
    }
  }
}
